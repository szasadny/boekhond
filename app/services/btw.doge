so "../../lib/geld.doge"
so "../../lib/datum.doge"

# De enige plek met fiscale rekenregels (Hard Rule 5).
# Specificatie: .claude/DATA-MODEL.md §2 — elke code mapt op precies één rubriek-gedrag.
#   grondslag: rubriek waar bedrag_ex in telt (none = geen)
#   btw:       rubriek waar het btw-bedrag in telt (none = geen)
#   aftrek:    btw telt ook als voorbelasting (5b)
#   zelf:      btw wordt zelf aangegeven, niet aan de wederpartij betaald (incl = ex)
so CODES = {
    "hoog_21": {"soort": "verkoop", "pct": 21, "grondslag": "1a", "btw": "1a", "aftrek": false, "zelf": false},
    "laag_9": {"soort": "verkoop", "pct": 9, "grondslag": "1b", "btw": "1b", "aftrek": false, "zelf": false},
    "nul_binnenland": {"soort": "verkoop", "pct": 0, "grondslag": "1e", "btw": none, "aftrek": false, "zelf": false},
    "verlegd_naar_afnemer": {"soort": "verkoop", "pct": 0, "grondslag": "1e", "btw": none, "aftrek": false, "zelf": false},
    "vrijgesteld": {"soort": "verkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false},
    "export_buiten_eu": {"soort": "verkoop", "pct": 0, "grondslag": "3a", "btw": none, "aftrek": false, "zelf": false},
    "levering_eu": {"soort": "verkoop", "pct": 0, "grondslag": "3b", "btw": none, "aftrek": false, "zelf": false},
    "voorbelasting_hoog": {"soort": "inkoop", "pct": 21, "grondslag": none, "btw": none, "aftrek": true, "zelf": false},
    "voorbelasting_laag": {"soort": "inkoop", "pct": 9, "grondslag": none, "btw": none, "aftrek": true, "zelf": false},
    "verlegd_naar_mij": {"soort": "inkoop", "pct": 21, "grondslag": "2a", "btw": "2a", "aftrek": true, "zelf": true},
    "import_buiten_eu": {"soort": "inkoop", "pct": 21, "grondslag": "4a", "btw": "4a", "aftrek": true, "zelf": true},
    "verwerving_eu": {"soort": "inkoop", "pct": 21, "grondslag": "4b", "btw": "4b", "aftrek": true, "zelf": true},
    "geen_btw": {"soort": "inkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false},
}

so RUBRIEKEN = ["1a", "1b", "1e", "2a", "3a", "3b", "4a", "4b"]

such info much code:
    if not CODES.has(code):
        bonk "onbekende btw-code: {code}"
    return CODES[code]
wow

such bestaat much code:
    return CODES.has(code)
wow

such btw_bedrag much bedrag_ex, code:
    such c = info(code)
    if c["pct"] == 0:
        return dec("0")
    return geld.rond2(bedrag_ex * c["pct"] / 100)
wow

# Wat er daadwerkelijk betaald wordt: bij zelf-aangeven-codes komt er
# geen btw op de factuur van de wederpartij, dus incl == ex.
such bedrag_incl much bedrag_ex, code:
    such c = info(code)
    if c["zelf"]:
        return bedrag_ex
    return bedrag_ex + btw_bedrag(bedrag_ex, code)
wow

# Aangifte in hele euro's; afronden in eigen voordeel is toegestaan:
# verschuldigde btw naar beneden, voorbelasting naar boven.
such euro_af much bedrag:
    return int(bedrag)
wow

such euro_op much bedrag:
    such hele = int(bedrag)
    if bedrag > hele:
        return hele + 1
    return hele
wow

# Grondslag van één journaalregel op zijn natuurlijke kant: omzet (verkoop) staat
# op credit, kosten/inkoop op debet. Antisymmetrisch, dus een storno (gespiegelde
# debet/credit) nettoot vanzelf negatief.
such regel_grondslag much r, soort:
    such d = geld.bedrag(r["debet"])
    such c = geld.bedrag(r["credit"])
    if soort == "verkoop":
        return c - d
    return d - c
wow

# Alle rubrieken voor één tijdvak, uit de journaalposten van dat tijdvak.
# Elke regel met een btw_code is een grondslagregel; de btw wordt hier afgeleid
# (invariant 1 — nooit uit een opgeslagen veld gelezen).
# Resultaat: {"rubrieken": {rubriek: {"bedrag", "btw"}}, "5a", "5b", "saldo"} — alles hele euro's (Int).
such rubrieken much posten, j, kw:
    such grondslag = {}
    such btw_som = {}
    for r in RUBRIEKEN:
        grondslag[r] = dec("0")
        btw_som[r] = dec("0")
    such voorbelasting = dec("0")
    for p in posten:
        if not datum.in_kwartaal(p["datum"], j, kw):
            continue
        for regel in p["regels"]:
            if not regel.has("btw_code") or regel["btw_code"] == none:
                continue
            such code = regel["btw_code"]
            such c = info(code)
            such ex = regel_grondslag(regel, c["soort"])
            such bb = btw_bedrag(ex, code)
            if c["grondslag"] != none:
                grondslag[c["grondslag"]] += ex
            if c["btw"] != none:
                btw_som[c["btw"]] += bb
            if c["aftrek"]:
                voorbelasting += bb
    such per_rubriek = {}
    such r5a = 0
    for r in RUBRIEKEN:
        such b_afgerond = euro_af(btw_som[r])
        per_rubriek[r] = {"bedrag": euro_af(grondslag[r]), "btw": b_afgerond}
        r5a += b_afgerond
    such r5b = euro_op(voorbelasting)
    return {"rubrieken": per_rubriek, "5a": r5a, "5b": r5b, "saldo": r5a - r5b}
wow
wow
