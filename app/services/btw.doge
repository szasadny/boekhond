so "../../lib/geld.doge"
so "../../lib/datum.doge"

# De enige plek met fiscale rekenregels (Hard Rule 5).
# Specificatie: .claude/DATA-MODEL.md §2 — elke code mapt op precies één rubriek-gedrag.
#   grondslag: rubriek waar bedrag_ex in telt (none = geen)
#   btw:       rubriek waar het btw-bedrag in telt (none = geen)
#   aftrek:    btw telt ook als voorbelasting (5b)
#   zelf:      btw wordt zelf aangegeven, niet aan de wederpartij betaald (incl = ex)
#   label:     menselijke naam voor de UI-dropdowns
#   uitleg:    korte betekenis voor de legenda in de invoerformulieren
so CODES = {
    "hoog_21": {"soort": "verkoop", "pct": 21, "grondslag": "1a", "btw": "1a", "aftrek": false, "zelf": false, "label": "Omzet 21%", "uitleg": "Verkoop met 21% btw. Telt in rubriek 1a."},
    "laag_9": {"soort": "verkoop", "pct": 9, "grondslag": "1b", "btw": "1b", "aftrek": false, "zelf": false, "label": "Omzet 9%", "uitleg": "Verkoop met 9% btw. Telt in rubriek 1b."},
    "nul_binnenland": {"soort": "verkoop", "pct": 0, "grondslag": "1e", "btw": none, "aftrek": false, "zelf": false, "label": "Omzet 0% (binnenland)", "uitleg": "Binnenlandse verkoop tegen 0%. Telt in rubriek 1e."},
    "verlegd_naar_afnemer": {"soort": "verkoop", "pct": 0, "grondslag": "1e", "btw": none, "aftrek": false, "zelf": false, "label": "Btw verlegd naar klant", "uitleg": "Je verlegt de btw naar je afnemer. Telt in rubriek 1e."},
    "vrijgesteld": {"soort": "verkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false, "label": "Vrijgestelde omzet", "uitleg": "Vrijgesteld van btw. Telt niet mee in de aangifte-rubrieken."},
    "export_buiten_eu": {"soort": "verkoop", "pct": 0, "grondslag": "3a", "btw": none, "aftrek": false, "zelf": false, "label": "Export buiten EU", "uitleg": "Verkoop naar buiten de EU tegen 0%. Telt in rubriek 3a."},
    "levering_eu": {"soort": "verkoop", "pct": 0, "grondslag": "3b", "btw": none, "aftrek": false, "zelf": false, "label": "Levering binnen EU", "uitleg": "Verkoop naar een ander EU-land tegen 0%. Telt in rubriek 3b."},
    "prive_gebruik": {"soort": "verkoop", "pct": 21, "grondslag": "1d", "btw": "1d", "aftrek": false, "zelf": true, "label": "Privégebruik (btw-correctie)", "uitleg": "Btw-correctie over privégebruik van zakelijke goederen of diensten. Alleen in de laatste aangifte van het jaar (Q4). Telt in rubriek 1d en 5a."},
    "voorbelasting_hoog": {"soort": "inkoop", "pct": 21, "grondslag": none, "btw": none, "aftrek": true, "zelf": false, "label": "Inkoop 21% (btw terugvragen)", "uitleg": "NL-leverancier met 21% btw die je als voorbelasting terugvraagt (rubriek 5b)."},
    "voorbelasting_laag": {"soort": "inkoop", "pct": 9, "grondslag": none, "btw": none, "aftrek": true, "zelf": false, "label": "Inkoop 9% (btw terugvragen)", "uitleg": "NL-leverancier met 9% btw die je terugvraagt (rubriek 5b)."},
    "verlegd_naar_mij": {"soort": "inkoop", "pct": 21, "grondslag": "2a", "btw": "2a", "aftrek": true, "zelf": true, "label": "Btw verlegd naar mij (NL)", "uitleg": "Binnenlandse verlegging: je geeft de btw zelf aan en trekt 'm af (rubriek 2a + 5b)."},
    "import_buiten_eu": {"soort": "inkoop", "pct": 21, "grondslag": "4a", "btw": "4a", "aftrek": true, "zelf": true, "label": "Inkoop buiten EU (btw verlegd)", "uitleg": "Dienst van buiten de EU, bijvoorbeeld US-SaaS. Btw verlegd naar jou: zelf aangeven en aftrekken (rubriek 4a + 5b)."},
    "verwerving_eu": {"soort": "inkoop", "pct": 21, "grondslag": "4b", "btw": "4b", "aftrek": true, "zelf": true, "label": "Inkoop binnen EU (btw verlegd)", "uitleg": "Goederen of diensten uit een ander EU-land met verlegde btw (rubriek 4b + 5b)."},
    "geen_btw": {"soort": "inkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false, "label": "Geen btw", "uitleg": "Kosten zonder btw, zoals verzekering of bankkosten."},
    "horeca": {"soort": "inkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false, "label": "Horeca (btw niet aftrekbaar)", "uitleg": "Eten en drinken in de horeca: de btw is niet aftrekbaar. Boek het bedrag inclusief btw als kosten."},
    "relatiegeschenk_bua": {"soort": "inkoop", "pct": 0, "grondslag": none, "btw": none, "aftrek": false, "zelf": false, "label": "Relatiegeschenk/personeel (BUA)", "uitleg": "Giften, relatiegeschenken en personeelsvoorzieningen boven 227 euro per ontvanger per jaar: btw niet aftrekbaar (BUA)."},
}

so RUBRIEKEN = ["1a", "1b", "1d", "1e", "2a", "3a", "3b", "4a", "4b"]

# Menselijk label voor een btw-code (voor de UI-dropdowns); valt terug op de code zelf.
such label much code:
    if CODES.has(code) and CODES[code].has("label"):
        return CODES[code]["label"]
    return code
wow

# Legenda-regels voor de invoerformulieren: [{code, label, uitleg}] voor een soort
# ("inkoop", "verkoop" of "alle").
such legenda much soort:
    such uit = []
    for c in CODES:
        if soort == "alle" or CODES[c]["soort"] == soort:
            uit.append({"code": c, "label": CODES[c]["label"], "uitleg": CODES[c]["uitleg"]})
    return uit
wow

such info much code:
    if not CODES.has(code):
        bonk "onbekende btw-code: {code}"
    return CODES[code]
wow

such bestaat much code:
    return CODES.has(code)
wow

such btw_bedrag much bedrag_ex, code:
    such c = info(code)
    if c["pct"] == 0:
        return dec("0")
    return geld.rond2(bedrag_ex * c["pct"] / 100)
wow

# Wat er daadwerkelijk betaald wordt: bij zelf-aangeven-codes komt er
# geen btw op de factuur van de wederpartij, dus incl == ex.
such bedrag_incl much bedrag_ex, code:
    such c = info(code)
    if c["zelf"]:
        return bedrag_ex
    return bedrag_ex + btw_bedrag(bedrag_ex, code)
wow

# Inverse van bedrag_incl: splits een inclusief bedrag in [ex, btw]. btw = incl - ex (de
# rest), zodat ex + btw == incl exact — een post op deze splitsing balanceert. Voor de
# Mollie-import, die inclusieve bedragen levert. Afronding blijft hier (Hard Rule 5).
such splits_incl much bedrag_incl, code:
    such c = info(code)
    if c["pct"] == 0:
        return [bedrag_incl, dec("0")]
    such ex = geld.rond2(bedrag_incl * 100 / (100 + c["pct"]))
    such btw = bedrag_incl - ex
    return [ex, btw]
wow

# Aangifte in hele euro's; afronden in eigen voordeel is toegestaan:
# verschuldigde btw naar beneden, voorbelasting naar boven.
such euro_af much bedrag:
    return int(bedrag)
wow

such euro_op much bedrag:
    such hele = int(bedrag)
    if bedrag > hele:
        return hele + 1
    return hele
wow

# Grondslag van één journaalregel op zijn natuurlijke kant: omzet (verkoop) staat
# op credit, kosten/inkoop op debet. Antisymmetrisch, dus een storno (gespiegelde
# debet/credit) nettoot vanzelf negatief.
such regel_grondslag much r, soort:
    such d = geld.bedrag(r["debet"])
    such c = geld.bedrag(r["credit"])
    if soort == "verkoop":
        return c - d
    return d - c
wow

# Alle rubrieken voor één tijdvak, uit de journaalposten van dat tijdvak.
# Elke regel met een btw_code is een grondslagregel; de btw wordt hier afgeleid
# (invariant 1 — nooit uit een opgeslagen veld gelezen).
# Resultaat: {"rubrieken": {rubriek: {"bedrag", "btw"}}, "5a", "5b", "saldo"} — alles hele euro's (Int).
such rubrieken much posten, j, kw:
    such grondslag = {}
    such btw_som = {}
    for r in RUBRIEKEN:
        grondslag[r] = dec("0")
        btw_som[r] = dec("0")
    such voorbelasting = dec("0")
    for p in posten:
        if not datum.in_kwartaal(p["datum"], j, kw):
            continue
        for regel in p["regels"]:
            if not regel.has("btw_code") or regel["btw_code"] == none:
                continue
            such code = regel["btw_code"]
            such c = info(code)
            such ex = regel_grondslag(regel, c["soort"])
            such bb = btw_bedrag(ex, code)
            if c["grondslag"] != none:
                grondslag[c["grondslag"]] += ex
            if c["btw"] != none:
                btw_som[c["btw"]] += bb
            if c["aftrek"]:
                voorbelasting += bb
    such per_rubriek = {}
    such r5a = 0
    for r in RUBRIEKEN:
        such b_afgerond = euro_af(btw_som[r])
        per_rubriek[r] = {"bedrag": euro_af(grondslag[r]), "btw": b_afgerond}
        r5a += b_afgerond
    such r5b = euro_op(voorbelasting)
    return {"rubrieken": per_rubriek, "5a": r5a, "5b": r5b, "saldo": r5a - r5b}
wow

# Netto btw-effect van één post op de cent (Decimal): verschuldigde btw minus voorbelasting.
# Een storno (gespiegelde regels) nettoot vanzelf negatief. Voor het suppletie-signaal in
# aangifte.doge — btw-rekenwerk blijft hier.
such post_effect much post:
    such verschuldigd = dec("0")
    such voor = dec("0")
    for regel in post["regels"]:
        if not regel.has("btw_code") or regel["btw_code"] == none:
            continue
        such code = regel["btw_code"]
        such c = info(code)
        such ex = regel_grondslag(regel, c["soort"])
        such bb = btw_bedrag(ex, code)
        if c["btw"] != none:
            very verschuldigd = verschuldigd + bb
        if c["aftrek"]:
            very voor = voor + bb
    return verschuldigd - voor
wow

# Som van de grondslag (Decimal) over alle regels met deze btw_code in jaar j. Voor de
# vrijgestelde-omzet-noot op het jaaroverzicht (vrijgesteld valt buiten RUBRIEKEN).
such grondslag_voor_code much posten, j, code:
    such c = info(code)
    such som = dec("0")
    for p in posten:
        if datum.jaar(p["datum"]) != j:
            continue
        for regel in p["regels"]:
            if not regel.has("btw_code") or regel["btw_code"] == none:
                continue
            if regel["btw_code"] == code:
                very som = som + regel_grondslag(regel, c["soort"])
    return som
wow
wow
