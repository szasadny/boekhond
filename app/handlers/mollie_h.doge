# Mollie-overzicht: laatste sync, reeds geboekte Mollie-posten, en een handmatige
# "sync nu"-knop. De echte sync-logica zit in app/services/mollie.doge.

such mollie_posten much store:
    such uit = []
    for p in store.laad("journaal", []):
        if p["bron"] == "mollie":
            uit.append(p)
    return uit
