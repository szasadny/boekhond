    else:
        very actie = "<p class=\"fout\">Geen MOLLIE_API_KEY geconfigureerd (.env).</p>"
    return "{melding}<h1>Inkomsten</h1><p>Laatste sync: {lstxt}</p>{actie}{tabel}"
