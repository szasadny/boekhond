so env
so fetch
so strings
so howl
so pack
so nap
so "lib/datum.doge"
so "web/http.doge"
so "web/router.doge"
so "web/static.doge"
so "app/store/store.doge"
so "app/services/rekeningen.doge"
so "app/handlers/rekeningen_h.doge"
so "app/handlers/journaal_h.doge"
so "app/handlers/dashboard_h.doge"
so "app/handlers/bijlagen_h.doge"
so "app/handlers/aangifte_h.doge"
so "app/handlers/rapporten_h.doge"
so "app/handlers/mollie_h.doge"
so "app/handlers/terugkerend_h.doge"
so "app/handlers/intern_h.doge"

# Boot + wiring (ARCHITECTURE §2/§6.6). Geen login: single-user, LAN/VPN-only —
# het netwerk is de grens, niet een wachtwoord. Handlers krijgen state via
# req["ctx"] (de router roept handler(req) positioneel; closures kunnen de
# bootstate niet bereiken).

so STATIC_ROOT = "static"
so STATIC_PREFIX = "/static/"

# Strip één paar omringende quotes (VALUE of "VALUE" of 'VALUE' in .env).
such ontquote much s:
    if len(s) >= 2:
        such eerste = s[0]
        such laatste = s[len(s) - 1]
        if eerste == laatste and (eerste == "\"" or eerste == "'"):
            return s[1:len(s) - 1]
    return s
wow

# .env-bestand → Dict (KEY=VALUE per regel; # is commentaar, lege regels overgeslagen).
# Ontbreekt het bestand, dan leeg — de echte environment blijft de bron (docker compose
# injecteert via env_file, dan is dit leeg). Secrets blijven in .env, nooit in source (Hard Rule 8).
such dotenv:
    such d = {}
    if not fetch.exists(".env"):
        return d
    for regel in strings.split(fetch.read(".env"), "\n"):
        such r = strings.trim(regel)
        if r == "" or r[0] == "#" or not strings.contains(r, "="):
            continue
        such sleutel = strings.trim(strings.split(r, "=")[0])
        such waarde = strings.trim(r[len(strings.split(r, "=")[0]) + 1:])
        d[sleutel] = ontquote(waarde)
    return d
wow

# Config-waarde: echte env-var wint, dan .env-bestand, anders none. Zo overriden
# expliciete exports en `docker compose env_file` altijd het bestand.
such haal much sleutel, envd:
    such v = env.get(sleutel)
    if v != none:
        return v
    if envd.has(sleutel):
        return envd[sleutel]
    return none
wow

# .env één keer bij boot; instance-config uit de environment of het .env-bestand.
such config:
    such envd = dotenv()
    such poort = haal("POORT", envd)
    if poort == none:
        very poort = "8085"
    such data_dir = haal("DATA_DIR", envd)
    if data_dir == none:
        very data_dir = "data"
    such mollie_key = haal("MOLLIE_API_KEY", envd)
    such intern_token = haal("INTERN_TOKEN", envd)
    such bind_host = haal("BIND_HOST", envd)
    if bind_host == none:
        very bind_host = "127.0.0.1"
    return {"poort": int(poort), "data_dir": data_dir, "mollie_key": mollie_key, "intern_token": intern_token, "bind_host": bind_host}
wow

such health much req:
    return http.tekst_response(200, "ok")
wow

# Routes; handlers registreren zichzelf nooit.
such maak_router:
    such r = router.Router()
    r.voeg_toe("GET", "/health", health)
    r.voeg_toe("GET", "/", dashboard_h.home)
    r.voeg_toe("GET", "/rekeningen", rekeningen_h.lijst)
    r.voeg_toe("POST", "/rekeningen", rekeningen_h.toevoegen)
    r.voeg_toe("POST", "/rekeningen/\{nummer\}/deactiveer", rekeningen_h.deactiveer)
    r.voeg_toe("GET", "/journaal", journaal_h.lijst)
    r.voeg_toe("GET", "/journaal/inkoop", journaal_h.inkoop_form)
    r.voeg_toe("POST", "/journaal/inkoop", journaal_h.inkoop)
    r.voeg_toe("GET", "/journaal/bank", journaal_h.bank_form)
    r.voeg_toe("POST", "/journaal/bank", journaal_h.bank)
    r.voeg_toe("GET", "/journaal/memoriaal", journaal_h.memoriaal_form)
    r.voeg_toe("POST", "/journaal/memoriaal", journaal_h.memoriaal)
    r.voeg_toe("GET", "/journaal/storno", journaal_h.storno_form)
    r.voeg_toe("POST", "/journaal/storno", journaal_h.storno)
    r.voeg_toe("GET", "/journaal/export.csv", journaal_h.export_csv)
    r.voeg_toe("GET", "/aangifte", aangifte_h.overzicht)
    r.voeg_toe("GET", "/aangifte/doen", aangifte_h.doen)
    r.voeg_toe("POST", "/aangifte/privegebruik", aangifte_h.boek_privegebruik)
    r.voeg_toe("POST", "/aangifte/dien-in", aangifte_h.dien_in)
    r.voeg_toe("GET", "/aangifte/export.csv", aangifte_h.export_csv)
    r.voeg_toe("GET", "/aangifte/print", aangifte_h.print_view)
    r.voeg_toe("GET", "/aangiften", aangifte_h.lijst)
    r.voeg_toe("GET", "/rapporten/balans", rapporten_h.balans)
    r.voeg_toe("GET", "/rapporten/balans.csv", rapporten_h.balans_csv)
    r.voeg_toe("GET", "/rapporten/winst-verlies", rapporten_h.winst_verlies)
    r.voeg_toe("GET", "/rapporten/winst-verlies.csv", rapporten_h.winst_verlies_csv)
    r.voeg_toe("GET", "/rapporten/jaaroverzicht", rapporten_h.jaaroverzicht)
    r.voeg_toe("GET", "/rapporten/jaaroverzicht.csv", rapporten_h.jaaroverzicht_csv)
    r.voeg_toe("GET", "/mollie", mollie_h.overzicht)
    r.voeg_toe("POST", "/mollie/sync", mollie_h.sync)
    r.voeg_toe("GET", "/terugkerend", terugkerend_h.lijst)
    r.voeg_toe("POST", "/terugkerend", terugkerend_h.toevoegen)
    r.voeg_toe("POST", "/terugkerend/\{id\}/deactiveer", terugkerend_h.deactiveer)
    r.voeg_toe("POST", "/terugkerend/genereer", terugkerend_h.genereer)
    r.voeg_toe("POST", "/internal/run-recurring", intern_h.run_recurring)
    r.voeg_toe("GET", "/upload", bijlagen_h.upload_form)
    r.voeg_toe("POST", "/upload", bijlagen_h.upload)
    r.voeg_toe("GET", "/inbox", bijlagen_h.inbox)
    r.voeg_toe("POST", "/inbox/scan", bijlagen_h.scan)
    r.voeg_toe("POST", "/koppel", bijlagen_h.koppel)
    r.voeg_toe("GET", "/bijlagen/\{id\}", bijlagen_h.download)
    return r
wow

such begint_met much s, voorvoegsel:
    if len(s) < len(voorvoegsel):
        return false
    return s[0:len(voorvoegsel)] == voorvoegsel
wow

# Eén verbinding: parse -> static / router -> stuur. Alles in één pls/oh no,
# zodat een fout een schone 500 geeft en de accept-loop nooit sneuvelt.
such afhandel much conn, r, winkel, cfg:
    pls
        such req = http.parse_request(conn)
        if req == none:
            return
        such pad = req["path"]
        such resp = none
        if begint_met(pad, STATIC_PREFIX):
            very resp = static.bedien(STATIC_ROOT, pad[7:])
        else:
            req["ctx"] = {"store": winkel, "config": cfg}
            req["peer_host"] = http.peer_host(conn)
            very resp = r.verwerk(req)
        howl.send_bytes(conn, http.bouw_response(resp))
    oh no err!
        bark "verzoekfout: " + err.message
        pls
            howl.send_bytes(conn, http.bouw_response(http.tekst_response(500, "interne fout")))
        oh no err2!
            bark "kon 500 niet sturen: " + err2.message
wow

# Scheduler-pup (§5.2): eigen thread, deelt geen state — loopback-HTTP is het enige kanaal.
# Slaapt tot het volgende 06:00 en POSTt dan /internal/run-recurring met het INTERN_TOKEN.
# De handler draait op de main-loop (deelt dus wél de store) en doet de drie idempotente
# stappen. Fouten blijven binnen de lus zodat de pup nooit sneuvelt.
such scheduler_lus much cfg:
    such poort = cfg["poort"]
    such token = cfg["intern_token"]
    while true:
        nap.rest(datum.seconden_tot_uur(6))
        pls
            such url = "http://127.0.0.1:{poort}/internal/run-recurring"
            such opts = {"headers": {"X-Intern-Token": token}}
            such resp = howl.request("POST", url, opts)
            such st = resp["status"]
            bark "scheduler: run-recurring status {st}"
        oh no err!
            bark "scheduler-fout: {err.message}"
wow

such start:
    such cfg = config()
    such winkel = store.Store(cfg["data_dir"])
    rekeningen.seed(winkel)
    such r = maak_router()
    such host = cfg["bind_host"]
    such listener = howl.listen(host, cfg["poort"])
    such p = cfg["poort"]
    bark "boekhond luistert op {host}:{p}"
    if cfg["intern_token"] != none:
        pack.zoom(scheduler_lus, [cfg])
    else:
        bark "geen INTERN_TOKEN: scheduler-pup niet gestart"
    while true:
        such conn = howl.accept(listener)
        afhandel(conn, r, winkel, cfg)
        howl.close(conn)
wow

start()
wow
