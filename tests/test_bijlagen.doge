wow

such test_weiger_te_groot:
    such s = verse()
    such gevangen = false
    pls
        bijlagen.bewaar(s, deel("groot.pdf", groter_dan(bijlagen.MAX_BYTES)), "upload")
    oh no err!
        very gevangen = true
    amaze gevangen
    schoon()
wow

such test_koppel_zet_beide_kanten:
    such s = verse()
    such m = bijlagen.bewaar(s, deel("f.pdf", bytes([1, 2])), "upload")
    such post = maak_post(s)
    bijlagen.koppel(s, m["id"], post["id"])
    such bl = bijlagen.zoek(bijlagen.alle(s), m["id"])
    amaze bl["journaalpost_id"] == post["id"]
    such posten = s.laad("journaal", [])
    amaze posten[0]["bijlage_ids"].contains(m["id"])
    amaze len(bijlagen.inbox(s)) == 0
    schoon()
wow

such test_koppel_vergrendeld_bonkt:
    such s = verse()
    such m = bijlagen.bewaar(s, deel("f.pdf", bytes([1, 2])), "upload")
    such post = maak_post(s)
    s.bewaar("aangiften", [{"id": "a-1", "jaar": 2026, "tijdvak": "Q3", "status": "ingediend"}])
    such gevangen = false
    pls
        bijlagen.koppel(s, m["id"], post["id"])
    oh no err!
        very gevangen = true
    amaze gevangen
    amaze len(bijlagen.inbox(s)) == 1
    schoon()
wow

such test_inbox_filtert_gekoppelde:
    such s = verse()
    bijlagen.bewaar(s, deel("a.pdf", bytes([1])), "upload")
    such tweede = bijlagen.bewaar(s, deel("b.pdf", bytes([2])), "upload")
    amaze len(bijlagen.inbox(s)) == 2
    such post = maak_post(s)
    bijlagen.koppel(s, tweede["id"], post["id"])
    amaze len(bijlagen.inbox(s)) == 1
    amaze len(bijlagen.alle(s)) == 2
    schoon()
wow

such test_scan_importeert:
    such s = verse()
    drop("factuur.pdf", bytes("%PDF-1.4 test"))
    such res = bijlagen.scan_import(s)
    amaze res["geimporteerd"] == 1
    such items = bijlagen.inbox(s)
    amaze len(items) == 1
    amaze items[0]["bron"] == "import"
    amaze items[0]["bestandsnaam_origineel"] == "factuur.pdf"
    amaze not fetch.exists(import_pad("factuur.pdf"))
    amaze fetch.exists(fetch.join(TMPMAP, items[0]["pad"]))
    schoon()
wow

such test_scan_idempotent:
    such s = verse()
    drop("factuur.pdf", bytes("%PDF-1.4 test"))
    bijlagen.scan_import(s)
    such res = bijlagen.scan_import(s)
    amaze res["geimporteerd"] == 0
    amaze len(bijlagen.inbox(s)) == 1
    schoon()
wow

such test_scan_slaat_ongeldig_over:
    such s = verse()
    drop("notitie.txt", bytes("hallo"))
    such res = bijlagen.scan_import(s)
    amaze res["geimporteerd"] == 0
    amaze len(res["overgeslagen"]) == 1
    amaze fetch.exists(import_pad("notitie.txt"))
    amaze len(bijlagen.inbox(s)) == 0
    schoon()
wow

such test_scan_zonder_map:
    such s = verse()
    such res = bijlagen.scan_import(s)
    amaze res["geimporteerd"] == 0
    amaze len(res["overgeslagen"]) == 0
    schoon()
wow
wow
