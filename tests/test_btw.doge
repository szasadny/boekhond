so "../app/services/btw.doge"

# Bouwt een minimale journaalpost met één grondslagregel: omzet (verkoop) op
# credit, kosten/inkoop op debet — de natuurlijke kant die rubrieken() verwacht.
such maak much d, code, ex:
    such c = btw.info(code)
    such regel = {"rekening": "0000", "debet": "", "credit": "", "btw_code": code}
    if c["soort"] == "verkoop":
        regel["credit"] = ex
    else:
        regel["debet"] = ex
    return {"datum": d, "regels": [regel]}
wow

such test_btw_bedrag:
    amaze btw.btw_bedrag(dec("100"), "hoog_21") == dec("21")
    amaze btw.btw_bedrag(dec("100"), "laag_9") == dec("9")
    amaze btw.btw_bedrag(dec("100"), "export_buiten_eu") == dec("0")
    amaze btw.btw_bedrag(dec("999.99"), "hoog_21") == dec("210.00")
    amaze btw.btw_bedrag(dec("0.01"), "hoog_21") == dec("0")
    amaze btw.btw_bedrag(dec("100"), "verlegd_naar_mij") == dec("21")
wow

such test_bedrag_incl:
    amaze btw.bedrag_incl(dec("100"), "hoog_21") == dec("121")
    amaze btw.bedrag_incl(dec("100"), "voorbelasting_hoog") == dec("121")
    amaze btw.bedrag_incl(dec("100"), "verlegd_naar_mij") == dec("100")
    amaze btw.bedrag_incl(dec("100"), "import_buiten_eu") == dec("100")
    amaze btw.bedrag_incl(dec("100"), "vrijgesteld") == dec("100")
wow

such test_onbekende_code:
    such gevangen = false
    pls
        btw.btw_bedrag(dec("1"), "bestaat_niet")
    oh no err!
        very gevangen = true
    amaze gevangen
    amaze btw.bestaat("hoog_21")
    amaze not btw.bestaat("bestaat_niet")
wow

such test_rubrieken_kwartaal:
    such boekingen = []
    boekingen.append(maak("2026-07-01", "hoog_21", "1000"))
    boekingen.append(maak("2026-08-15", "laag_9", "500"))
    boekingen.append(maak("2026-09-30", "voorbelasting_hoog", "200"))
    boekingen.append(maak("2026-07-20", "verlegd_naar_mij", "100"))
    boekingen.append(maak("2026-07-05", "export_buiten_eu", "750"))
    boekingen.append(maak("2026-06-30", "hoog_21", "9999"))
    such r = btw.rubrieken(boekingen, 2026, 3)
    amaze r["rubrieken"]["1a"]["bedrag"] == 1000
    amaze r["rubrieken"]["1a"]["btw"] == 210
    amaze r["rubrieken"]["1b"]["bedrag"] == 500
    amaze r["rubrieken"]["1b"]["btw"] == 45
    amaze r["rubrieken"]["2a"]["bedrag"] == 100
    amaze r["rubrieken"]["2a"]["btw"] == 21
    amaze r["rubrieken"]["3a"]["bedrag"] == 750
    amaze r["rubrieken"]["3b"]["bedrag"] == 0
    amaze r["5a"] == 276
    amaze r["5b"] == 63
    amaze r["saldo"] == 213
wow

such test_afronding_voordelig:
    such boekingen = []
    boekingen.append(maak("2026-01-10", "hoog_21", "10.50"))
    boekingen.append(maak("2026-02-10", "voorbelasting_hoog", "10.50"))
    such r = btw.rubrieken(boekingen, 2026, 1)
    amaze r["rubrieken"]["1a"]["bedrag"] == 10
    amaze r["rubrieken"]["1a"]["btw"] == 2
    amaze r["5b"] == 3
    amaze r["saldo"] == -1
wow

such test_storno_telt_negatief:
    such boekingen = []
    boekingen.append(maak("2026-04-01", "hoog_21", "1000"))
    boekingen.append(maak("2026-05-01", "hoog_21", "-1000"))
    such r = btw.rubrieken(boekingen, 2026, 2)
    amaze r["rubrieken"]["1a"]["bedrag"] == 0
    amaze r["rubrieken"]["1a"]["btw"] == 0
    amaze r["saldo"] == 0
wow

such test_post_effect:
    amaze btw.post_effect(maak("2026-01-01", "hoog_21", "1000")) == dec("210")
    amaze btw.post_effect(maak("2026-01-01", "voorbelasting_hoog", "100")) == dec("-21")
    amaze btw.post_effect(maak("2026-01-01", "import_buiten_eu", "100")) == dec("0")
wow

such test_splits_incl:
    such s = btw.splits_incl(dec("12.10"), "hoog_21")
    amaze s[0] == dec("10.00")
    amaze s[1] == dec("2.10")
    such g = btw.splits_incl(dec("100"), "geen_btw")
    amaze g[0] == dec("100")
    amaze g[1] == dec("0")
wow

# Elke code moet een niet-lege label + uitleg hebben, anders lekt een rauwe code in een dropdown.
such test_elke_code_heeft_label_en_uitleg:
    for c in btw.CODES:
        amaze btw.CODES[c].has("label")
        amaze btw.CODES[c].has("uitleg")
        amaze btw.CODES[c]["label"] != ""
        amaze btw.CODES[c]["uitleg"] != ""
wow

such test_label_valt_terug_op_code:
    amaze btw.label("import_buiten_eu") == "Inkoop buiten EU (btw verlegd)"
    amaze btw.label("bestaat_niet") == "bestaat_niet"
wow

such test_legenda_filtert_op_soort:
    such ink = btw.legenda("inkoop")
    for e in ink:
        amaze btw.CODES[e["code"]]["soort"] == "inkoop"
    such alle = btw.legenda("alle")
    amaze len(alle) == len(btw.CODES)
    amaze len(ink) < len(alle)
wow

# Privégebruik (rubriek 1d): grondslag op de credit-kant (soort verkoop), btw 21% -> 1d, telt in 5a.
such test_privegebruik_1d:
    such boekingen = []
    boekingen.append(maak("2026-12-31", "prive_gebruik", "500"))
    such r = btw.rubrieken(boekingen, 2026, 4)
    amaze r["rubrieken"]["1d"]["bedrag"] == 500
    amaze r["rubrieken"]["1d"]["btw"] == 105
    amaze r["5a"] == 105
    amaze r["5b"] == 0
    amaze r["saldo"] == 105
wow

# Aftrekbeperkingen (horeca, BUA): kosten zonder aftrek -> geen enkele rubriek, geen 5a/5b-effect.
such test_aftrekbeperking_geen_rubriek:
    such boekingen = []
    boekingen.append(maak("2026-01-10", "horeca", "100"))
    boekingen.append(maak("2026-01-11", "relatiegeschenk_bua", "250"))
    such r = btw.rubrieken(boekingen, 2026, 1)
    amaze r["5a"] == 0
    amaze r["5b"] == 0
    amaze r["saldo"] == 0
    amaze btw.post_effect(maak("2026-01-10", "horeca", "100")) == dec("0")
wow
wow
