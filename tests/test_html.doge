so strings
so "../web/html.doge"

such test_escape_tags:
    amaze html.escape("<script>alert(1)</script>") == "&lt;script&gt;alert(1)&lt;/script&gt;"
wow

such test_escape_ampersand_eerst:
    amaze html.escape("a&b") == "a&amp;b"
    amaze html.escape("&lt;") == "&amp;lt;"
wow

such test_escape_quotes:
    amaze html.escape("\"'") == "&quot;&#39;"
wow

such test_link_escaped:
    such l = html.link("/x?a=1&b=2", "<b>klik</b>")
    amaze strings.contains(l, "href=\"/x?a=1&amp;b=2\"")
    amaze strings.contains(l, "&lt;b&gt;klik&lt;/b&gt;")
    amaze not strings.contains(l, "<b>")
wow

such test_tabel_cellen_escaped:
    such t = html.tabel(["Naam"], [["<b>kabosu</b>"]])
    amaze strings.contains(t, "<th>Naam</th>")
    amaze strings.contains(t, "&lt;b&gt;kabosu&lt;/b&gt;")
    amaze not strings.contains(t, "<b>kabosu")
wow

such test_pagina_bevat_titel_en_body:
    such p = html.pagina("Overzicht", "<p>hoi</p>")
    amaze strings.contains(p, "<!DOCTYPE html>")
    amaze strings.contains(p, "<title>Overzicht</title>")
    amaze strings.contains(p, "<p>hoi</p>")
wow

such test_pagina_laadt_deferred_script:
    such p = html.pagina("Overzicht", "<p>hoi</p>")
    amaze strings.contains(p, "<script src=\"/static/js/boekhond.js\" defer></script>")
    amaze strings.contains(p, "boekhond.js\" defer></script>\n</body>")
wow

such test_formulier_en_veld:
    such v = html.veld("bedrag", "Bedrag", "text", "12,50")
    such f = html.formulier("/kosten", "post", [v])
    amaze strings.contains(f, "<form action=\"/kosten\" method=\"post\">")
    amaze strings.contains(f, "name=\"bedrag\"")
    amaze strings.contains(f, "value=\"12,50\"")
wow

such test_bestand_veld:
    such b = html.bestand("bewijs", "Inkoopbewijs", ".pdf,.png")
    amaze strings.contains(b, "<label>Inkoopbewijs<input type=\"file\" name=\"bewijs\"")
    amaze strings.contains(b, "accept=\".pdf,.png\"")
wow

such test_formulier_enctype:
    such f = html.formulier("/upload", "post", [html.bestand("bewijs", "Bewijs")], "multipart/form-data")
    amaze strings.contains(f, "method=\"post\" enctype=\"multipart/form-data\"")
    such g = html.formulier("/x", "post", [])
    amaze strings.contains(g, "<form action=\"/x\" method=\"post\">")
wow

such test_select_gekozen_en_escaped:
    such s = html.select("btw_code", [["hoog_21", "21%"], ["geen_btw", "<geen>"]], "geen_btw")
    amaze strings.contains(s, "<select name=\"btw_code\">")
    amaze strings.contains(s, "<option value=\"hoog_21\">21%</option>")
    amaze strings.contains(s, "<option value=\"geen_btw\" selected>&lt;geen&gt;</option>")
    amaze not strings.contains(s, "value=\"hoog_21\" selected")
wow

such test_link_klasse:
    such a = html.link("/journaal", "Journaal", "actief")
    amaze strings.contains(a, "<a href=\"/journaal\" class=\"actief\">Journaal</a>")
    such b = html.link("/x", "y")
    amaze b == "<a href=\"/x\">y</a>"
wow

such test_tabel_rechts_uitlijning:
    such t = html.tabel(["Naam", "Bedrag"], [["kabosu", "12,50"]], [1])
    amaze strings.contains(t, "<th class=\"num\">Bedrag</th>")
    amaze strings.contains(t, "<td class=\"num\">12,50</td>")
    amaze strings.contains(t, "<th>Naam</th>")
    amaze strings.contains(t, "<td>kabosu</td>")
    such u = html.tabel(["Naam"], [["kabosu"]])
    amaze not strings.contains(u, "class=\"num\"")
wow

such test_staafgrafiek:
    such g = html.staafgrafiek("Omzet", [["jan", 100, "1.000", ""], ["feb", 50, "500", "negatief"]])
    amaze strings.contains(g, "<figure class=\"grafiek\">")
    amaze strings.contains(g, "<figcaption>Omzet</figcaption>")
    amaze strings.contains(g, "style=\"width:100%\"")
    amaze strings.contains(g, "class=\"balk negatief\"")
    amaze strings.contains(g, "jan")
    such x = html.staafgrafiek("t", [["<b>", 10, "v", ""]])
    amaze strings.contains(x, "&lt;b&gt;")
    such leeg = html.staafgrafiek("Leeg", [])
    amaze strings.contains(leeg, "<figure class=\"grafiek\">")
wow
wow
